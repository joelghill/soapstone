{
  "lexicon": 1,
  "id": "social.soapstone.feed.post",
  "defs": {
    "main": {
      "type": "record",
      "description": "A soapstone post: a templated message left at a geographic location, in the style of Dark Souls orange soapstone messages.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["message", "location", "createdAt"],
        "properties": {
          "message": {
            "type": "ref",
            "ref": "social.soapstone.message.defs#message"
          },
          "location": {
            "type": "ref",
            "ref": "social.soapstone.location.defs#location"
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
